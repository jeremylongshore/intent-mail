# Multi-Provider AI API Configuration
# Copy to .env and fill in your actual keys

# ============================================================================
# CLOUD PROVIDERS
# ============================================================================

# Groq API (Fastest free tier)
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Cerebras API (1M tokens/day free)
# Get key at: https://www.cerebras.ai/inference
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Together.ai ($25 free credits)
# Get key at: https://www.together.ai
TOGETHER_API_KEY=your_together_api_key_here

# Hugging Face Inference API (optional)
# Get token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_hf_token_here

# ============================================================================
# LOCAL MODELS
# ============================================================================

# Ollama Configuration
# Install from: https://ollama.ai
# Default runs on localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# Llamafile Configuration (optional)
# Download from: https://huggingface.co/Mozilla
LLAMAFILE_PATH=/path/to/Llama-3.2-1B-Instruct-llamafile
LLAMAFILE_PORT=8080

# ============================================================================
# ROUTER SETTINGS
# ============================================================================

# Max retries across all providers
MAX_RETRIES=3

# Default timeout for API calls (seconds)
API_TIMEOUT=30

# Enable/disable specific providers
ENABLE_GROQ=true
ENABLE_CEREBRAS=true
ENABLE_TOGETHER=true
ENABLE_OLLAMA=true

# Logging level
LOG_LEVEL=INFO

# ============================================================================
# COST & RATE LIMIT TRACKING
# ============================================================================

# Track usage per month (reset monthly)
MONTHLY_BUDGET_USD=50.0

# Rate limit thresholds (requests per minute)
GROQ_RATE_LIMIT=14400  # per day
CEREBRAS_RATE_LIMIT=unlimited  # 1M tokens per day
TOGETHER_RATE_LIMIT=36  # per hour on free tier
OLLAMA_RATE_LIMIT=unlimited  # local

# ============================================================================
# OPTIONAL: ADVANCED SETTINGS
# ============================================================================

# Use specific models per provider (override defaults)
# GROQ_MODEL=llama-3.3-70b-versatile
# CEREBRAS_MODEL=llama-3.1-70b
# TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Preferred provider order (comma-separated)
# PROVIDER_PRIORITY=groq,cerebras,together,ollama

# Enable caching of responses (experimental)
ENABLE_RESPONSE_CACHE=false

# Database for usage tracking (optional)
# DATABASE_URL=sqlite:///ai_usage.db
